# Postgres
POSTGRES_USER=tricouture
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=tricouture
# DATABASE_URL utilisé par l'app (host = nom du service compose "db")
DATABASE_URL=postgres://tricouture:change-me-please@db:5432/tricouture

# App — URL publique réelle (doit correspondre à ce que voit le navigateur).
# Remplace par TON domaine en production, ex. https://tricouture.exemple.fr
ORIGIN=http://localhost:3000
# Secret pour signer les sessions (générer: openssl rand -hex 32)
AUTH_SECRET=change-me-32-bytes-hex

# Chemin de stockage des fichiers uploadés (monté en volume)
MEDIA_DIR=/data/media

# --- Phases IA (sidecars GPU), optionnel pour le socle ---
# Laisse OLLAMA_URL vide pour désactiver l'IA (les boutons renvoient un message clair).
OLLAMA_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text
VISION_URL=http://vision:8000
WHISPER_URL=http://whisper:9000

# --- Exposition Internet (optionnel) ---
# Cloudflare Tunnel (voir docs/SELF-HOSTING.md §7) :
CLOUDFLARE_TUNNEL_TOKEN=
